// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Poll {
  id                    String   @id @default(cuid())
  title                 String
  optionATitle          String
  optionADescription    String?
  optionAImage          String?
  optionBTitle          String
  optionBDescription    String?
  optionBImage          String?
  deadline              DateTime?
  vetoZeroPctThreshold  Float    @default(0.2)
  closeDiffPctThreshold Float    @default(0.05)
  showResultsToAll      Boolean  @default(false)
  allowEditBeforeDeadline Boolean @default(true)
  adminToken            String   @default(cuid())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  votes                 Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  pollId    String
  name      String
  scoreA    Int
  scoreB    Int
  userAgent String?
  ipHash    String?
  location  String?  // 地理位置
  excluded  Boolean  @default(false) // 是否被排除
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, name])
  @@index([pollId])
}
